# -----------------------------------------------
# Nelly Proxy – Konfiguration
# Diese Datei als .env kopieren und ausfüllen:
#   cp .env.example .env
# -----------------------------------------------

# Mistral API
MISTRAL_API_KEY=hier_deinen_mistral_api_key_eintragen
MISTRAL_AGENT_ID=hier_deine_agent_id_eintragen

# Server
PORT=443
# Kommagetrennte Liste erlaubter Domains
ALLOWED_ORIGINS=https://nele-campus.org,https://www.nele-campus.org,https://app.nele-campus.org

# E-Mail (Office 365)
MAIL_USER=nele@pacemaker-initiative.de
MAIL_PASSWORD=hier_das_passwort_eintragen
MAIL_RECIPIENTS=konstantin.kaiser@pacemaker-initiative.de,sarah.soell@pacemaker-initiative.de,cinja.pettyjohn@pacemaker-initiative.de,nele@pacemaker-initiative.de

# Logs: Anzahl Tage bis zur automatischen Löschung
LOG_RETENTION_DAYS=90

# Sicherheits-Token für den manuellen Export-Link (bitte ersetzen!)
EXPORT_TOKEN=hier_einen_langen_zufaelligen_token_eintragen
